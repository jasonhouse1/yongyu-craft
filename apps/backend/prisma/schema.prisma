generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  category    String
  description String?
  priceType   PriceType @default(inquiry)
  price       Decimal?  @db.Decimal(12, 2)
  priceMin    Decimal?  @db.Decimal(12, 2)
  priceMax    Decimal?  @db.Decimal(12, 2)
  currency    String    @default("TWD")
  imageUrl    String?
  isAvailable Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

enum PriceType {
  fixed
  range
  inquiry
}

model Work {
  id                   String        @id @default(uuid())
  slug                 String        @unique
  titleZh              String
  titleEn              String?
  subtitleZh           String?
  subtitleEn           String?
  descriptionZh        String
  descriptionEn        String?
  storyZh              String?
  storyEn              String?
  categoryId           String
  materials            String[]
  techniques           String[]
  dimensions           String?
  weight               String?
  year                 String?
  priceType            WorkPriceType @default(inquiry)
  price                Decimal?      @db.Decimal(12, 2)
  priceMin             Decimal?      @db.Decimal(12, 2)
  priceMax             Decimal?      @db.Decimal(12, 2)
  currency             String        @default("TWD")
  isAvailable          Boolean       @default(true)
  isCustomizable       Boolean       @default(false)
  isFeatured           Boolean       @default(false)
  status               WorkStatus    @default(draft)
  coverImage           String        @default("")
  images               Json          @default("[]")
  videoUrl             String?
  sortOrder            Int           @default(0)
  seoTitleZh           String?
  seoTitleEn           String?
  seoDescriptionZh     String?
  seoDescriptionEn     String?
  aiSummaryZh          String?
  aiSummaryEn          String?
  aiKnowledgeZh        String?
  aiKnowledgeEn        String?
  careInstructionsZh   String?
  careInstructionsEn   String?
  inquiryNotesZh       String?
  inquiryNotesEn       String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([categoryId])
  @@index([status, sortOrder])
  @@index([isFeatured])
  @@map("works")
}

enum WorkPriceType {
  fixed
  range
  inquiry
}

enum WorkStatus {
  draft
  published
  archived
}

model WorkImage {
  id         String   @id @default(uuid())
  workId     String
  url        String
  altZh      String?
  altEn      String?
  captionZh  String?
  captionEn  String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([workId, sortOrder])
  @@map("work_images")
}

model Category {
  id        String   @id @default(uuid())
  slugZh    String   @unique
  slugEn    String   @unique
  nameZh    String
  nameEn    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Inquiry {
  id                String        @id @default(uuid())
  name              String
  email             String
  phone             String?
  message           String
  products          Json?
  lineId            String?
  whatsapp          String?
  country           String?
  inquiryType       InquiryType   @default(artwork)
  workId            String?
  budgetRange       String?
  purpose           String?
  needsShipping     Boolean       @default(false)
  contactPreference String?
  status            InquiryStatus @default(newInquiry)
  adminNote         String?
  repliedAt         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([inquiryType])
  @@map("inquiries")
}

enum InquiryType {
  artwork
  custom
  appointment
  corporate
  international
}

enum InquiryStatus {
  newInquiry @map("new")
  pending
  replied
  contacted
  negotiating
  completed
  closed
}

model Order {
  id            String      @id @default(uuid())
  inquiryId     String?
  status        OrderStatus @default(pending)
  totalAmount   Decimal     @db.Decimal(12, 2)
  currency      String      @default("TWD")
  paymentMethod String?
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("orders")
}

enum OrderStatus {
  pending
  paid
  cancelled
  refunded
}

model SnapshotSequence {
  scope      String   @id
  currentSeq BigInt   @default(0)
  updatedAt  DateTime @updatedAt

  @@map("snapshot_sequences")
}

model OutboxEvent {
  eventId       String    @id @default(uuid())
  topic         String    @default("default")
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  metadata      Json      @default("{}")
  causationId   String?
  correlationId String
  status        String    @default("pending")
  retryCount    Int       @default(0)
  lastRetryAt   DateTime?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  processedAt   DateTime?

  @@index([status, processedAt])
  @@index([aggregateType, aggregateId, createdAt])
  @@index([correlationId])
  @@map("outbox_events")
}